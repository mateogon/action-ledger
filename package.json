{
  "name": "action-ledger",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first action ledger for agent-managed tasks, projects, and reminders.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build:packages && npm run build -w @action-ledger/desktop",
    "build:packages": "tsc -b packages/*",
    "cli": "node packages/cli/dist/bin/acc.js",
    "mcp": "node packages/mcp-server/dist/bin/acc-mcp.js",
    "desktop:dev": "npm run tauri -w @action-ledger/desktop -- dev",
    "desktop:open": "open \"apps/desktop/src-tauri/target/release/bundle/macos/Action Ledger.app\"",
    "desktop:build": "npm run tauri -w @action-ledger/desktop -- build",
    "desktop:check": "npm run tauri -w @action-ledger/desktop -- build --no-bundle",
    "desktop:rust:test": "cd apps/desktop/src-tauri && cargo test",
    "test": "vitest --run",
    "test:watch": "vitest",
    "typecheck": "tsc -b packages/* apps/desktop --pretty"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.20"
  },
  "license": "MIT"
}
